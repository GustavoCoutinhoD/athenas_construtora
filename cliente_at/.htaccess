# ══════════════════════════════════════════════════════════════════
#  ATHENAS Construtora — Configuração de Segurança Apache
#  Protege contra: XSS, Clickjacking, MIME Sniffing, Info Disclosure
#  Data: 2026-05
# ══════════════════════════════════════════════════════════════════

# ── Bloqueia listagem de diretórios ─────────────────────────────
Options -Indexes

# ── Segurança em uploads/follows simbólicos ──────────────────────
Options -FollowSymLinks +SymLinksIfOwnerMatch

# ── Headers de segurança HTTP ────────────────────────────────────
<IfModule mod_headers.c>

  # Impede clickjacking — site não pode ser embutido em iframe
  Header always set X-Frame-Options "DENY"

  # Impede MIME sniffing — browser respeita Content-Type declarado
  Header always set X-Content-Type-Options "nosniff"

  # Controla informação enviada no Referer
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Restringe APIs do browser desnecessárias (câmera, mic, GPS, etc.)
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), fullscreen=(self)"

  # Força HTTPS por 1 ano + subdomínios (ativar só após HTTPS garantido)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Content Security Policy — controla de onde recursos podem vir
  Header always set Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net data:; img-src 'self' data: blob:; media-src 'self'; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"

  # Remove headers que revelam tecnologia do servidor
  Header always unset Server
  Header always unset X-Powered-By
  Header always unset X-AspNet-Version
  Header always unset X-AspNetMvc-Version

  # Proteção XSS legada (IE/Edge antigos)
  Header always set X-XSS-Protection "1; mode=block"

  # Impede download automático de arquivos em contexto errado
  Header always set X-Download-Options "noopen"

  # Controla como dados são compartilhados em cross-origin
  Header always set Cross-Origin-Resource-Policy "same-site"
  Header always set Cross-Origin-Opener-Policy "same-origin"

</IfModule>

# ── Bloqueia acesso a arquivos sensíveis ─────────────────────────
<FilesMatch "(^\.htaccess|^\.htpasswd|^\.env|^\.git|prompt\.txt|\.ifc$|\.sql$|\.bak$|\.backup$|\.log$|\.config$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# ── Bloqueia acesso a diretório .claude ──────────────────────────
<DirectoryMatch "\.claude">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</DirectoryMatch>

# ── Bloqueia métodos HTTP desnecessários ─────────────────────────
<LimitExcept GET HEAD OPTIONS>
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</LimitExcept>

# ── Bloqueia User-Agents maliciosos comuns ───────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Força HTTPS
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP_HOST} !^localhost [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Bloqueia user-agents de scanners e ferramentas de ataque
  RewriteCond %{HTTP_USER_AGENT} (sqlmap|nikto|nmap|masscan|dirbuster|wfuzz|burpsuite|acunetix|nessus|openvas|w3af|havij|pangolin) [NC]
  RewriteRule .* - [F,L]

  # Bloqueia requisições com caracteres de injeção na URL
  RewriteCond %{QUERY_STRING} (<|>|%3C|%3E|%0A|%0D|%27|%22|union|select|insert|drop|truncate|exec|script) [NC]
  RewriteRule .* - [F,L]

  # Bloqueia traversal de diretórios
  RewriteCond %{REQUEST_URI} \.\. [NC]
  RewriteRule .* - [F,L]

</IfModule>

# ── Cache otimizado + seguro ─────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                  "access plus 1 hour"
  ExpiresByType text/css                   "access plus 1 year"
  ExpiresByType application/javascript     "access plus 1 year"
  ExpiresByType image/jpeg                 "access plus 6 months"
  ExpiresByType image/png                  "access plus 6 months"
  ExpiresByType image/webp                 "access plus 6 months"
  ExpiresByType model/gltf-binary          "access plus 1 month"
  ExpiresByType application/octet-stream   "access plus 1 month"
  ExpiresByType font/woff2                 "access plus 1 year"
</IfModule>

# ── Compressão (performance + segurança) ────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml
</IfModule>
